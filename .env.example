# Local MongoDB container
MONGO_PORT=27017
MONGO_ROOT_USERNAME=cst_admin
MONGO_ROOT_PASSWORD=replace_with_a_strong_local_password
MONGO_DATABASE=cst_crm

# Backend connection string. Keep authSource=admin for the Docker root user.
MONGODB_URI=mongodb://cst_admin:replace_with_a_strong_local_password@localhost:27017/cst_crm?authSource=admin

# Application defaults
FRONTEND_URL=http://localhost:3000
BACKEND_PORT=5000
JWT_SECRET=replace_with_at_least_32_random_characters
TZ=Asia/Karachi

AUTO_SEED_DIRECTOR=true
DIRECTOR_NAME=Director Admin
DIRECTOR_EMAIL=director@cstcrm.com
DIRECTOR_PASSWORD=Director@12345
CST_INTEGRATION_SECRET=development-sales-integration-key
